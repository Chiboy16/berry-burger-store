app.post("/api/payment-webhook", (req, res) => {
    try {
        const db = loadDB();
        const data = req.body;

        const reference = data?.data?.reference;
        const status = data?.data?.status;

        if (!db.payments[reference]) return res.sendStatus(404);
        if (db.payments[reference].status === "success") return res.sendStatus(200);

        if (status === "success") {
            const payment = db.payments[reference];
            const userId = payment.userId;

            if (!db.users[userId]) db.users[userId] = { balance: 0, ref: null };

            // Determine if this is a first-time fund to process referral bonuses safely
            const transactionList = db.history[userId] || [];
            const hasDepositedBefore = transactionList.some(t => t.type === "deposit");

            db.users[userId].balance += payment.amount;
            logTransaction(db, userId, "deposit", payment.amount, `Wallet Top Up Ref: ${reference}`);
            db.payments[reference].status = "success";

            // Process referral rewards if conditions match safely
            if (!hasDepositedBefore && db.users[userId].ref) {
                const uplineReferrer = db.users[userId].ref;
                if (db.users[uplineReferrer]) {
                    const commissionReward = Math.floor((payment.amount * REFERRAL_BONUS_PERCENT) / 100);
                    db.users[uplineReferrer].balance += commissionReward;
                    
                    if (!db.usedRefs[uplineReferrer]) db.usedRefs[uplineReferrer] = 0;
                    db.usedRefs[uplineReferrer] += commissionReward;

                    logTransaction(db, uplineReferrer, "deposit", commissionReward, `Referral bonus from new user ${userId}`);
                    bot.sendMessage(uplineReferrer, `🎁 **Referral Bonus Credited!**\n\nYour invitee \`${userId}\` funded their account. You received **₦${commissionReward}**!`, { parse_mode: "Markdown" });
                }
            }

            saveDB(db);
            bot.sendMessage(userId, `💳 **Payment Confirmed Successful!**\n\n**₦${payment.amount}** has been credited to your active wallet balance ledger.`);
        } else if (status === "failed") {
            db.payments[reference].status = "failed";
            saveDB(db);
        }
        res.sendStatus(200);
    } catch (e) {
        res.sendStatus(500);
    }
});

